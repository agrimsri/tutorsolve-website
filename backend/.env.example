SECRET_KEY=your-long-random-secret-key-here
JWT_SECRET_KEY=your-long-random-jwt-secret-here

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=tutorsolve

# Stripe (Phase 3)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Razorpay (Phase 3)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# AWS S3 (Phase 8)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=tutorsolve-files
AWS_REGION=ap-south-1

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Geo IP — https://ipapi.co
GEO_API_KEY=

# CORS — comma-separated list of allowed frontend origins
# Development: http://localhost:3000
# Production:  https://tutorsolve.com,https://www.tutorsolve.com
CORS_ORIGINS=http://localhost:3000

REDIS_SOCKETIO_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2
